{
  "name": "agent-link",
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development bun --watch src/server.ts",
    "build": "bun build src/server.ts --outdir dist --target bun",
    "build:binary": "bun build src/server.ts --compile --outfile dist/agent-link"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "hono": "^4.12.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11"
  }
}
